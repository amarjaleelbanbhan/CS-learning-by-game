{
  "name": "@arc/design-system",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind-preset": {
      "types": "./tailwind-preset.d.ts",
      "default": "./tailwind-preset.cjs"
    }
  },
  "files": [
    "dist",
    "tailwind-preset.cjs",
    "tailwind-preset.d.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint src"
  }
}
